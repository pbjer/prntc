---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("writing")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const isEditor = process.env.EDITOR === "true";
---

<Base>
  <h1>Prentice Bjerkeseth</h1>
  <p class="links"><a href="https://github.com/pbjer">github</a> · <a href="https://www.linkedin.com/in/prentice-bjerkeseth-abb77399/">linkedin</a></p>

  {isEditor && <button id="new-post">New Post</button>}

  {isEditor && (
    <script>
      document.getElementById("new-post")!.addEventListener("click", async () => {
        const title = prompt("Post title:");
        if (!title) return;
        const res = await fetch("/api/posts", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ title }),
        });
        const { slug } = await res.json();
        window.location.href = `/writing/${slug}`;
      });
    </script>
  )}

  {
    posts.length === 0 ? (
      <p class="empty">Nothing here yet.</p>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <a href={`/writing/${post.id}`}>
              <span class="post-title">{post.data.title}</span>
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "numeric",
                })}
              </time>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</Base>

<style>
  h1 {
    font-family: ui-monospace, monospace;
    font-size: 1.125rem;
    font-weight: 500;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .links {
    margin-bottom: 3rem;
  }

  .links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.875rem;
  }

  .links a:hover {
    color: var(--text);
  }

  #new-post {
    font-family: var(--sans);
    font-size: 0.75rem;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: none;
    color: var(--text-muted);
    cursor: pointer;
  }

  #new-post:hover {
    color: var(--text);
    border-color: var(--text-muted);
  }

  .empty {
    color: var(--text-muted);
    font-family: var(--serif);
  }

  .post-list {
    list-style: none;
  }

  .post-list a {
    display: block;
    text-decoration: none;
    color: var(--text);
    padding: 0.125rem 0;
  }

  .post-list a:hover .post-title {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-title {
    font-size: 1rem;
  }

  time {
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin-left: 0.5rem;
  }
</style>
